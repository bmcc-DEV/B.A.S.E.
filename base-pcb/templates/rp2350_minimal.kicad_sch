; RP2350 Minimum System Template
; Template: RP2350 + 12MHz crystal + QSPI flash + USB-C + SWD
( symbol (lib_id "MCU_RP:Raspberry_Pi_RP2350") (at 100 100) (unit 1)
  (property "Reference" "U1" (at 0 0))
  (property "Value" "RP2350A" (at 0 0))
)
( symbol (lib_id "Device:Crystal") (at 50 200) (unit 1)
  (property "Reference" "Y1" (at 0 0))
  (property "Value" "12MHz" (at 0 0))
)
( symbol (lib_id "Device:C_Small") (at 30 220) (unit 1)
  (property "Reference" "C1" (at 0 0))
  (property "Value" "18pF" (at 0 0))
)
( symbol (lib_id "Device:C_Small") (at 70 220) (unit 1)
  (property "Reference" "C2" (at 0 0))
  (property "Value" "18pF" (at 0 0))
)
( symbol (lib_id "Memory_Flash:Winbond_W25Q128JV") (at 200 100) (unit 1)
  (property "Reference" "U2" (at 0 0))
  (property "Value" "W25Q128JV" (at 0 0))
)
( wire (pts (xy 150 100) (xy 200 100)))
