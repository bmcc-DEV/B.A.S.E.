  (property "Reference" "J1" (at 0 0))
  (property "Value" "USB-C" (at 0 0))
)
( symbol (lib_id "Device:R_Small") (at 80 140) (unit 1)
  (property "Reference" "R3" (at 0 0))
  (property "Value" "5.1k" (at 0 0))
)
( symbol (lib_id "Device:R_Small") (at 120 140) (unit 1)
  (property "Reference" "R4" (at 0 0))
  (property "Value" "5.1k" (at 0 0))
)
( symbol (lib_id "Device:C_Small") (at 100 50) (unit 1)
  (property "Reference" "C5" (at 0 0))
  (property "Value" "100nF" (at 0 0))
)
