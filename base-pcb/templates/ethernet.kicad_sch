; Ethernet PHY + Magnetics Template
( symbol (lib_id "Interface_Ethernet:WIZnet_W5500") (at 100 100) (unit 1)
  (property "Reference" "U4" (at 0 0))
  (property "Value" "W5500" (at 0 0))
)
( symbol (lib_id "Interface_Ethernet:HR911105A") (at 250 100) (unit 1)
  (property "Reference" "J2" (at 0 0))
  (property "Value" "RJ45" (at 0 0))
)
( symbol (lib_id "Device:C_Small") (at 100 180) (unit 1)
  (property "Reference" "C6" (at 0 0))
  (property "Value" "100nF" (at 0 0))
)
( symbol (lib_id "Device:C_Small") (at 120 180) (unit 1)
  (property "Reference" "C7" (at 0 0))
  (property "Value" "10uF" (at 0 0))
)
( wire (pts (xy 160 100) (xy 250 100)))
