; Audio Codec Template — I2S DAC + I2C control
( symbol (lib_id "Audio:TI_PCM5102A") (at 100 100) (unit 1)
  (property "Reference" "U5" (at 0 0))
  (property "Value" "PCM5102A" (at 0 0))
  (property "Footprint" "Package_SO:TSSOP-16_4.4x5mm_P0.65mm")
)
( symbol (lib_id "Device:C_Small") (at 80 160) (unit 1)
  (property "Reference" "C8" (at 0 0))
  (property "Value" "100nF" (at 0 0))
)
( symbol (lib_id "Device:C_Small") (at 120 160) (unit 1)
  (property "Reference" "C9" (at 0 0))
  (property "Value" "10uF" (at 0 0))
)
( symbol (lib_id "Device:R_Small") (at 100 50) (unit 1)
  (property "Reference" "R5" (at 0 0))
  (property "Value" "10k" (at 0 0))
)
( symbol (lib_id "audio:Jack_3.5mm") (at 250 100) (unit 1)
  (property "Reference" "J3" (at 0 0))
  (property "Value" "Audio Out" (at 0 0))
)
( wire (pts (xy 160 100) (xy 250 100)))
